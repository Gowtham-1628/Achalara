# Database
DATABASE_URL=postgresql://postgres:dev123@localhost:5432/pms_dev

# Google Sheets (for CSV/Sheets import)
GOOGLE_SHEETS_API_KEY=your_api_key_here
GOOGLE_SHEETS_CREDENTIALS_FILE=./credentials.json

# Webull market data
WEBULL_APP_KEY=your_webull_app_key_here
WEBULL_APP_SECRET=your_webull_app_secret_here

# Redis (for scheduler)
REDIS_URL=redis://localhost:6379/0

# Application
PYTHON_ENV=development
LOG_LEVEL=DEBUG
PORT=8000

# Scheduler
SCHEDULER_ENABLED=true

# CORS — comma-separated list of allowed frontend origins.
# Add your production URL(s) here; localhost:5173 covers local dev.
CORS_ALLOW_ORIGINS=http://localhost:5173

# Dev-only client login (POST /clients/login).
# Leave empty to disable the endpoint entirely (recommended for production).
# This is a stop-gap until real auth (Roadmap Phase 6) lands.
CLIENT_DEV_PASSWORD=

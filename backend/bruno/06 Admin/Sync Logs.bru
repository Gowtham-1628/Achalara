meta {
  name: Sync Logs
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/v1/admin/sync-logs?client_id={{clientId}}&skip=0&limit=100
  body: none
  auth: none
}

params:query {
  client_id: {{clientId}}
  skip: 0
  limit: 100
}

assert {
  res.status: eq 200
  res.body.total: isNumber
}

docs {
  Import/sync audit trail. `total` is the real row count (not the page size).
}

meta {
  name: Update Sync Config
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/api/v1/admin/sync-configs/{{configId}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "enabled": false
  }
}

assert {
  res.status: eq 200
  res.body.enabled: eq false
}

docs {
  Enable/disable an automated sync config without deleting it.
}

meta {
  name: Create Client
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/clients/
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Sarvani",
    "email": "vchamidiboyena@gmail.com"
  }
}

vars:post-response {
  clientId: res.body.id
}

assert {
  res.status: eq 201
  res.body.name: eq Acme Capital
}

script:pre-request {
  bru.setVar("clientEmail", "acme+" + Date.now() + "@example.com");
}
